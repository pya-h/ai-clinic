# ── General ──
APP_PORT=8080
APP_NAME=AI-Clinic
SLOGAN=Your Health, Our Priority
DEBUG=true

# ── Database ──
DATABASE_URL=postgresql://user:pass@localhost:5432/ai_clinic

# ── Auth ──
AUTH_SALT_ROUNDS=12
SESSION_SECRET=your-strong-session-secret-min-32-chars
SESSION_COOKIE_NAME=sid

# ── Seed / Superuser ──
SUPERUSER_EMAIL=admin@ai-clinic.com
SUPERUSER_PASSWORD=SuperAdmin123!

# ── CORS ──
CORS_ORIGIN=http://localhost:5173

# ── AI ──
BOTAGENT_KEY=your-botpress-webhook-id
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-3.5-turbo
BOTPRESS_BOT_ID=
BOTPRESS_API_KEY=

# ── Notifications ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=app-password
SMTP_FROM=AI-Clinic <noreply@ai-clinic.com>
VAPID_SUBJECT=mailto:admin@ai-clinic.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Calendly ──
CALENDLY_API_KEY=
CALENDLY_ORGANIZATION_URI=https://api.calendly.com/organizations/YOUR_ORG_UUID
CALENDLY_WEBHOOK_SIGNING_KEY=
CALENDLY_USER_URI=https://api.calendly.com/users/YOUR_USER_UUID

# ── Storage ──
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=