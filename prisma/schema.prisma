generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRolesEnum {
  NONE // ordinary or guest user
  DOCTOR
  NURSE
  ASSISTANT
  PATIENT
  STAFF
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  email               String            @unique
  firstname           String
  lastname            String
  role                UserRolesEnum     @map("user_role")
  isAdmin             Boolean           @default(false) @map("is_admin")
  isPrivate           Boolean           @default(false) @map("is_private")
  avatar              String?           @map("avatar")
  password            String
  chatHistory         ChatParticipant[]
  conversationsWithAI AiConversation[]
  patientSOAPs        PatientSOAP[]
  doctorProfile       DoctorProfile?
  reviewsOnDoctors    DoctorReview[]
  patientProfile      PatientProfile?
  visitsAttended      Visit[]

  @@map("user")
}

// Human-to-Human Interactions:
model Chat {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  closedAt  DateTime? @map("closed_at")

  topic    String?
  messages Message[]
  parties  ChatParticipant[]

  @@map("chat")
}

model Message {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chatId String @map("chat_id")
  chat   Chat   @relation(fields: [chatId], references: [id])

  repliedToId BigInt?  @map("replied_to_id")
  repliedTo   Message? @relation("MessageReply", fields: [repliedToId], references: [id])

  replies Message[] @relation("MessageReply")

  @@map("message")
}

model ChatParticipant {
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  chatId String @map("chat_id")
  chat   Chat   @relation(fields: [chatId], references: [id])

  @@id([chatId, userId])
  @@map("chat_participant")
}

enum AiAgentsEnum {
  BOTPRESS
  OPENAI
  GEMENI
  DEEPSEEK
  KIMI
  CLAUDE
  GROK
}

// Ai Interactions:
model AiConversation {
  id     String @id // Agent's generated Id = convesationId
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  topic        String?
  agentType    AiAgentsEnum  @default(BOTPRESS)
  createdAt    DateTime      @default(now()) @map("created_at")
  patientSOAPs PatientSOAP[]

  @@map("ai_conversation")
}

model PatientSOAP {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  conversationId String         @map("conversation_id")
  conversation   AiConversation @relation(fields: [conversationId], references: [id])

  note String @map("note")

  @@map("patient_soap")
}

enum VisitMethodsEnum {
  CHAT
  VOICE_CALL
  VIDEO_CALL
  ON_SITE
}

enum VisitStatusEnum {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum VisitTypesEnum {
  CONSULTATION
  EXAMINATION
  SURGERY
  LABORATORY
  RADIOLOGY
  PHARMACY
  DENTISTRY
  THERAPY
  NUTRITION
  OTHER
}

enum DoctorSpecialtiesEnum {
  CARDIOLOGY
  DERMATOLOGY
  ENT
  GASTROENTEROLOGY
  GYNECOLOGY
  NEUROLOGY
  ONCOLOGY
  ORTHOPEDICS
  PEDIATRICS
  PSYCHIATRY
  UROLOGY
  GENERAL
  OTHER
}

model DoctorProfile {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  startedAt            DateTime                @map("started_at")
  specialty            DoctorSpecialtiesEnum   @default(GENERAL)
  secondarySpecialties DoctorSpecialtiesEnum[] @map("secondary_specialties")

  university     String?
  location       String?
  clinicLocation String? @map("clinic_location")
  bio            String?

  visitMethods VisitMethodsEnum[] @map("visit_methods")
  visitTypes   VisitTypesEnum[]   @map("visit_types")

  verified        Boolean        @default(false)
  platformSummary String?        @map("platform_summuary")
  reviewsAbout    DoctorReview[]
  visits          Visit[]

  @@map("doctor_profile")
}

model DoctorReview {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reviewerId String @map("reviewer_id")
  reviewer   User   @relation(fields: [reviewerId], references: [id])

  doctorId Int           @map("doctor_id")
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  title    String?
  overview String? @map("overview")

  verified Boolean @default(false)
  rating   Int

  @@map("doctor_review")
}

model PatientProfile {
  id String @id @default(uuid())

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  location     String?
  visitMethods VisitMethodsEnum[] @map("visit_methods")
  bio          String?

  medicalHistory String[] @map("medical_history")
  allergies      String[] @map("allergies")
  medications    String[] @map("medications")
  surgeries      String[] @map("surgeries")
  familyHistory  String[] @map("family_history")

  @@map("patient_profile")
}

model Visit {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  patientId String @map("patient_id")
  patient   User   @relation(fields: [patientId], references: [id])

  doctorId Int           @map("doctor_id")
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  date      DateTime @map("date")
  startTime Int      @map("start_time") // in ms
  endTime   Int?     @map("end_time") // in ms

  method VisitMethodsEnum @map("method")
  type   VisitTypesEnum   @map("type")
  status VisitStatusEnum  @map("status")

  notes       String[] @map("notes")
  attachments String[] @map("attachments")

  scheduled Boolean @default(false) @map("scheduled")

  @@map("visit")
}
