// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRoles {
  NONE // ordinary or guest user
  DOCTOR
  NURSE
  ASSISTANT
  PATIENT
  STAFF
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  email               String            @unique
  firstname           String
  lastname            String
  role                UserRoles         @map("user_role")
  isAdmin             Boolean           @map("is_admin")
  isPrivate           Boolean           @map("is_private")
  avatar              String?           @map("avatar")
  password            String
  chatHistory         ChatParticipant[]
  conversationsWithAI AiConversation[]
  patientSOAPs        PatientSOAP[]
  doctorProfile       DoctorProfile?
  reviewsOnDoctors    DoctorReview[]

  @@map("user")
}

// Human-to-Human Interactions:
model Chat {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  closedAt  DateTime? @map("closed_at")

  topic    String?
  messages Message[]
  parties  ChatParticipant[]

  @@map("chat")
}

model Message {
  id        BigInt   @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  chatId String @map("chat_id")
  chat   Chat   @relation(fields: [chatId], references: [id])

  repliedToId BigInt?  @map("replied_to_id")
  repliedTo   Message? @relation("MessageReply", fields: [repliedToId], references: [id])

  replies Message[] @relation("MessageReply")

  @@map("message")
}

model ChatParticipant {
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])
  chatId String @map("chat_id")
  chat   Chat   @relation(fields: [chatId], references: [id])

  @@id([chatId, userId])
  @@map("chat_participant")
}

enum AiAgentsEnum {
  BOTPRESS
  OPENAI
  GEMENI
  DEEPSEEK
  KIMI
  CLAUDE
  GROK
}

// Ai Interactions:
model AiConversation {
  id     String @id // Agent's generated Id = convesationId
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  topic        String?
  agentType    AiAgentsEnum  @default(BOTPRESS)
  createdAt    DateTime      @default(now()) @map("created_at")
  patientSOAPs PatientSOAP[]

  @@map("ai_conversation")
}

model PatientSOAP {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  conversationId String         @map("conversation_id")
  conversation   AiConversation @relation(fields: [conversationId], references: [id])

  note String @map("note")

  @@map("patient_soap")
}

enum VisitMethods {
  CHAT
  VOICE_CALL
  VIDEO_CALL
  ON_SITE
}

model DoctorProfile {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  university     String?
  location       String?
  clinicLocation String?        @map("clinic_location")
  visitMethods   VisitMethods[] @map("visit_methods")
  bio            String?

  verified        Boolean        @default(false)
  platformSummary String?        @map("platform_summuary")
  reviewsAbout    DoctorReview[]

  @@map("doctor_profile")
}

model DoctorReview {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reviewerId String @map("reviewer_id")
  reviewer   User   @relation(fields: [reviewerId], references: [id])

  doctorId Int           @map("doctor_id")
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  title    String?
  overview String? @map("overview")

  verified Boolean @default(false)
  rating   Int

  @@map("doctor_review")
}
